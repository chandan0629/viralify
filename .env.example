# Environment Configuration
# Copy to .env and fill in actual values for production

# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=0
FLASK_PORT=5000

# Model Configuration
MODEL_DIR=backend/models
DATA_DIR=datasets

# Frontend Configuration
VITE_API_URL=http://localhost:5000
REACT_APP_API_URL=http://localhost:5000

# Live Analysis API (Standalone Server)
# Set this when running live_server.py on port 5001
REACT_APP_LIVE_API_URL=http://localhost:5001/api/live

# Or for Integrated Server (main server with blueprint)
# REACT_APP_LIVE_API_URL=http://localhost:5000/api/live

# CORS Configuration
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:3000

# Production Only
# SECRET_KEY=your-secret-key-here
# DATABASE_URL=your-database-url-here
# SSL_CERT=/path/to/cert.pem
# SSL_KEY=/path/to/key.pem
